{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-svelte",
  "version": "0.1.0",
  "identifier": "com.tauri-svelte.app",
  "build": {
    "beforeDevCommand": "pnpm --dir src-frontend/src-angular run start -- --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:angular",
    "frontendDist": "../src-frontend/src-angular/dist/browser"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
