  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build src-backend/wgpu-renderer --target web --out-dir ../../src-frontend/lib/wasm_gpu",
    "dev": "cd src-frontend && vite dev",
    "build": "pnpm build:wasm && cd src-frontend && vite build",
    "preview": "cd src-frontend && vite preview",
    "check": "cd src-frontend && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
